#!/bin/bash
# NexusOS System Update Script
# Updates system packages, AUR packages, and emulators

echo "╔════════════════════════════════════════╗"
echo "║  NexusOS System Update v1.0            ║"
echo "╚════════════════════════════════════════╝"
echo ""

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo "⚠️  This script requires sudo"
    exec sudo "$0" "$@"
fi

echo "🔄 Updating system packages..."
pacman -Syu --noconfirm

echo ""
echo "🎮 Updating emulators..."
# Update RetroArch cores
pacman -S --noconfirm libretro-*-git 2>/dev/null || true

echo ""
echo "📦 Updating AUR packages..."
sudo -u gamer pikaur -Su --noconfirm 2>/dev/null || true

echo ""
echo "✨ Clearing package cache..."
pacman -Sc --noconfirm

echo ""
echo "✅ Update complete!"
echo "Reboot recommended: sudo reboot"
